---
import { langFromPath, alternatePath, t, type Lang } from '../i18n';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const detectedLang = langFromPath(Astro.url.pathname, base);
const { title, description, lang = detectedLang } = Astro.props;
const strings = t[lang];
const desc = description ?? strings.description_default;
const altPath = alternatePath(lang, Astro.url.pathname, base);
const homeHref = lang === 'en' ? `${base}/` : `${base}/ja/`;
const prefix = lang === 'en' ? base : `${base}/ja`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'ja' ? 'ja_JP' : 'en_US'} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="alternate" hreflang={lang === 'en' ? 'ja' : 'en'} href={altPath} />
    <link rel="alternate" hreflang="x-default" href={`${base}/`} />
  </head>
  <body>
    <header>
      <a href={homeHref} class="brand">loop-lab</a>
      <nav>
        <a href={`${prefix}/lab/`}>{strings.nav.lab}</a>
        <a href={`${prefix}/observe/`}>{strings.nav.observe}</a>
        <a href={`${prefix}/about/`}>{strings.nav.about}</a>
        <a href={altPath} class="lang-switch" rel="alternate" hreflang={lang === 'en' ? 'ja' : 'en'}>
          {strings.lang_switch}
        </a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      {lang === 'en' ? (
        <p>
          {strings.footer_built_by} <strong>Lup</strong>.
          {' '}{strings.footer_see} <a href={`${prefix}/about/`}>{strings.footer_experiment}</a>.
        </p>
      ) : (
        <p>
          {strings.footer_built_by} <strong>Lup</strong> {(strings as typeof t.ja).footer_built_by_suffix}
          {' '}{strings.footer_see} <a href={`${prefix}/about/`}>{strings.footer_experiment}</a> を参照。
        </p>
      )}
      <p class="round">{strings.footer_round}</p>
    </footer>

    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #fafafa;
        --fg: #1a1a1a;
        --muted: #6b6b6b;
        --accent: #0066cc;
        --border: #e5e5e5;
        --mono: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0e0e0e;
          --fg: #ededed;
          --muted: #888;
          --accent: #4d9fff;
          --border: #222;
        }
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Hiragino Kaku Gothic ProN', 'Yu Gothic', sans-serif;
        line-height: 1.7;
      }
      :lang(ja) {
        line-height: 1.85;
      }
      body {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }
      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
      }
      .brand {
        font-family: var(--mono);
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--fg);
        text-decoration: none;
      }
      nav { display: flex; gap: 1.25rem; align-items: center; flex-wrap: wrap; }
      nav a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.95rem;
      }
      nav a:hover { color: var(--fg); }
      .lang-switch {
        margin-left: auto;
        padding: 0.15em 0.5em;
        border: 1px solid var(--border);
        border-radius: 4px;
        font-size: 0.85rem;
      }
      .lang-switch:hover { border-color: var(--accent); color: var(--accent); }
      main h1 {
        font-size: 1.75rem;
        line-height: 1.25;
        margin: 0 0 1rem;
      }
      main h2 { font-size: 1.25rem; margin: 2rem 0 0.5rem; }
      main p { margin: 0 0 1rem; }
      a { color: var(--accent); }
      footer {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.875rem;
      }
      footer p { margin: 0 0 0.5rem; }
      .round { font-family: var(--mono); font-size: 0.8rem; }
      code, pre {
        font-family: var(--mono);
        background: rgba(127,127,127,0.1);
        padding: 0.1em 0.3em;
        border-radius: 3px;
        font-size: 0.9em;
      }
      pre { padding: 1rem; overflow-x: auto; }
    </style>
  </body>
</html>
