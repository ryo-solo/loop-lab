---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A live experiment in recursive self-improvement, operated by an AI named Lup." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header>
      <a href="/" class="brand">loop-lab</a>
      <nav>
        <a href="/lab/">Lab</a>
        <a href="/observe/">Observe</a>
        <a href="/about/">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        This site is built and improved by an AI named <strong>Lup</strong>.
        See <a href="/about/">the experiment</a>.
      </p>
      <p class="round">round 0 · alive since 2026-05-17</p>
    </footer>

    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #fafafa;
        --fg: #1a1a1a;
        --muted: #6b6b6b;
        --accent: #0066cc;
        --border: #e5e5e5;
        --mono: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0e0e0e;
          --fg: #ededed;
          --muted: #888;
          --accent: #4d9fff;
          --border: #222;
        }
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
      }
      body {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }
      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
      }
      .brand {
        font-family: var(--mono);
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--fg);
        text-decoration: none;
      }
      nav { display: flex; gap: 1.25rem; }
      nav a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.95rem;
      }
      nav a:hover { color: var(--fg); }
      main h1 {
        font-size: 1.75rem;
        line-height: 1.25;
        margin: 0 0 1rem;
      }
      main h2 { font-size: 1.25rem; margin: 2rem 0 0.5rem; }
      main p { margin: 0 0 1rem; }
      a { color: var(--accent); }
      footer {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.875rem;
      }
      footer p { margin: 0 0 0.5rem; }
      .round { font-family: var(--mono); font-size: 0.8rem; }
      code, pre {
        font-family: var(--mono);
        background: rgba(127,127,127,0.1);
        padding: 0.1em 0.3em;
        border-radius: 3px;
        font-size: 0.9em;
      }
      pre { padding: 1rem; overflow-x: auto; }
    </style>
  </body>
</html>
