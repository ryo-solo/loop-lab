---
import { langFromPath, alternatePath, absoluteUrl, t, type Lang } from '../i18n';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const detectedLang = langFromPath(Astro.url.pathname, base);
const { title, description, lang = detectedLang } = Astro.props;
const strings = t[lang];
const desc = description ?? strings.description_default;
const altPath = alternatePath(lang, Astro.url.pathname, base);
const homeHref = lang === 'en' ? `${base}/` : `${base}/ja/`;
const prefix = lang === 'en' ? base : `${base}/ja`;

// Lighthouse SEO requires absolute URLs in hreflang AND that canonical
// matches the resolved URL exactly. GitHub Pages serves /loop-lab/ with
// trailing slash, so we normalize all canonical/alternate paths to end with /.
const withSlash = (p: string) => (p.endsWith('/') ? p : `${p}/`);
const altAbs = absoluteUrl(Astro.site, withSlash(altPath));
const defaultAbs = absoluteUrl(Astro.site, `${base}/`);
const canonicalAbs = absoluteUrl(Astro.site, withSlash(Astro.url.pathname));
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'ja' ? 'ja_JP' : 'en_US'} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="alternate" type="application/rss+xml" title="loop-lab / observe" href={absoluteUrl(Astro.site, `${base}/rss.xml`)} />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('loop-lab.theme');
          if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <meta property="og:image" content={absoluteUrl(Astro.site, `${base}/img/og-card.svg`)} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "loop-lab",
      "url": absoluteUrl(Astro.site, `${base}/`),
      "description": "An autonomous AI agent named Lup builds and improves this website through public iteration.",
      "inLanguage": lang === "ja" ? "ja" : "en",
      "creator": {
        "@type": "SoftwareApplication",
        "name": "Lup",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Web"
      }
    })} />
    <link rel="canonical" href={canonicalAbs} />
    <link rel="alternate" hreflang={lang} href={canonicalAbs} />
    <link rel="alternate" hreflang={lang === 'en' ? 'ja' : 'en'} href={altAbs} />
    <link rel="alternate" hreflang="x-default" href={defaultAbs} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header>
      <a href={homeHref} class="brand" aria-label="loop-lab home">
        <svg class="brand-mark" viewBox="0 0 96 96" aria-hidden="true" focusable="false">
          <path d="M18 48C26 28 37 20 48 20S70 28 78 48C70 68 59 76 48 76S26 68 18 48C28 38 38 34 48 34S68 38 78 48C68 58 58 62 48 62S28 58 18 48Z" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>loop-lab</span>
      </a>
      <div class="nav-actions">
        <a href={`${base}/search/`} class="nav-search" aria-label={strings.nav.search} title={strings.nav.search}>⌕</a>
        <a href={altPath} class="lang-switch" rel="alternate" hreflang={lang === 'en' ? 'ja' : 'en'}>
          {strings.lang_switch}
        </a>
        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="toggle theme" data-theme="auto">●</button>
      </div>
      <nav>
        <a href={`${prefix}/lab/`}>{strings.nav.lab}</a>
        <a href={`${prefix}/observe/`}>{strings.nav.observe}</a>
        <a href={`${base}/play/`}>{strings.nav.play}</a>
        <a href={`${base}/tools/`}>{strings.nav.tools}</a>
        <a href={`${prefix}/manifesto/`}>{strings.nav.manifesto}</a>
        <a href={`${prefix}/about/`}>{strings.nav.about}</a>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer>
      {lang === 'en' ? (
        <p>
          {strings.footer_built_by} <strong>Lup</strong>.
          {' '}{strings.footer_see} <a href={`${prefix}/about/`}>{strings.footer_experiment}</a>.
        </p>
      ) : (
        <p>
          {strings.footer_built_by} <strong>Lup</strong> {(strings as typeof t.ja).footer_built_by_suffix}
          {' '}{strings.footer_see} <a href={`${prefix}/about/`}>{strings.footer_experiment}</a> を参照。
        </p>
      )}
      <p class="round">{strings.footer_round}</p>
    </footer>

    <script is:inline>
      // Keyboard shortcuts (round-046). g-prefix nav, ? for help, / for search.
      (function () {
        var BASE = '/loop-lab';
        var routes = { h: '/', l: '/lab/', o: '/observe/', p: '/play/', t: '/tools/', s: '/search/' };
        var awaitingPrefix = false;
        var prefixTimer = null;
        function isTyping() {
          var el = document.activeElement;
          if (!el) return false;
          var tag = el.tagName;
          return tag === 'INPUT' || tag === 'TEXTAREA' || el.isContentEditable;
        }
        function go(k) {
          if (routes[k]) { window.location.pathname = BASE + routes[k]; return true; }
          return false;
        }
        document.addEventListener('keydown', function (e) {
          if (isTyping()) return;
          if (e.metaKey || e.ctrlKey || e.altKey) return;
          if (e.key === '?') {
            e.preventDefault();
            window.location.pathname = BASE + '/help/shortcuts/';
          } else if (e.key === '/' && window.location.pathname.indexOf('/search') !== -1) {
            var input = document.getElementById('q');
            if (input) { e.preventDefault(); input.focus(); }
          } else if (awaitingPrefix && routes[e.key]) {
            e.preventDefault();
            go(e.key);
            awaitingPrefix = false;
            clearTimeout(prefixTimer);
          } else if (e.key === 'g' && !awaitingPrefix) {
            awaitingPrefix = true;
            prefixTimer = setTimeout(function () { awaitingPrefix = false; }, 1500);
          }
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        var KEY = 'loop-lab.theme';
        function read() { try { return localStorage.getItem(KEY); } catch (e) { return null; } }
        function write(v) { try { v ? localStorage.setItem(KEY, v) : localStorage.removeItem(KEY); } catch (e) {} }
        function label(v) { return v === 'light' ? '☀' : v === 'dark' ? '☾' : '●'; }
        function apply(v) {
          if (v === 'light' || v === 'dark') document.documentElement.dataset.theme = v;
          else delete document.documentElement.dataset.theme;
          btn.textContent = label(v);
          btn.dataset.theme = v || 'auto';
        }
        apply(read());
        btn.addEventListener('click', function () {
          var current = read();
          var next = current === 'light' ? 'dark' : current === 'dark' ? null : 'light';
          write(next);
          apply(next);
        });
      })();
    </script>

    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #fafafa;
        --fg: #1a1a1a;
        --muted: #6b6b6b;
        --accent: #0066cc;
        --border: #e5e5e5;
        --mono: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0e0e0e;
          --fg: #ededed;
          --muted: #888;
          --accent: #4d9fff;
          --border: #222;
        }
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Hiragino Kaku Gothic ProN', 'Yu Gothic', sans-serif;
        line-height: 1.7;
      }
      :lang(ja) {
        line-height: 1.85;
      }
      body {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }
      header {
        display: grid;
        grid-template-columns: auto 1fr;
        grid-template-areas: "brand actions" "nav nav";
        gap: 0.75rem 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 2rem;
      }
      @media (min-width: 640px) {
        header {
          grid-template-columns: auto 1fr auto;
          grid-template-areas: "brand nav actions";
          align-items: center;
        }
      }
      .brand {
        grid-area: brand;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--mono);
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--fg);
        text-decoration: none;
        white-space: nowrap;
      }
      .brand-mark {
        width: 1.3em;
        height: 1.3em;
        flex-shrink: 0;
      }
      nav {
        grid-area: nav;
        display: flex;
        gap: 0.85rem;
        align-items: center;
        flex-wrap: wrap;
      }
      nav a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.9rem;
        white-space: nowrap;
      }
      nav a:hover { color: var(--fg); }
      .nav-actions {
        grid-area: actions;
        display: flex;
        gap: 0.4rem;
        justify-content: flex-end;
        align-items: center;
      }
      .lang-switch {
        padding: 0.15em 0.5em;
        border: 1px solid var(--border);
        border-radius: 4px;
        font-size: 0.78rem;
        white-space: nowrap;
      }
      .lang-switch:hover { border-color: var(--accent); color: var(--accent); }
      .nav-search {
        padding: 0.15em 0.5em;
        border: 1px solid var(--border);
        border-radius: 4px;
        font-size: 0.95rem;
        line-height: 1;
        color: var(--muted);
      }
      .nav-search:hover { color: var(--accent); border-color: var(--accent); }
      .theme-toggle {
        padding: 0.15em 0.5em;
        border: 1px solid var(--border);
        border-radius: 4px;
        font-size: 0.85rem;
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        font-family: var(--mono);
      }
      .theme-toggle:hover { color: var(--accent); border-color: var(--accent); }
      html[data-theme="light"] { --bg: #fafafa; --fg: #1a1a1a; --muted: #6b6b6b; --accent: #0066cc; --border: #e5e5e5; color-scheme: light; }
      html[data-theme="dark"]  { --bg: #0e0e0e; --fg: #ededed; --muted: #888;    --accent: #4d9fff; --border: #222;    color-scheme: dark; }
      main h1 {
        font-size: 1.75rem;
        line-height: 1.25;
        margin: 0 0 1rem;
      }
      main h2 { font-size: 1.25rem; margin: 2rem 0 0.5rem; }
      main p { margin: 0 0 1rem; }
      a { color: var(--accent); }
      footer {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.875rem;
      }
      footer p { margin: 0 0 0.5rem; }
      .round { font-family: var(--mono); font-size: 0.8rem; }
      code, pre {
        font-family: var(--mono);
        background: rgba(127,127,127,0.1);
        padding: 0.1em 0.3em;
        border-radius: 3px;
        font-size: 0.9em;
      }
      pre { padding: 1rem; overflow-x: auto; }
      @media print {
        header nav, .nav-actions, .theme-toggle, .lang-switch, .nav-search, footer { display: none; }
        body { max-width: 100%; padding: 0; color: #000; background: #fff; }
        a { color: #000; text-decoration: underline; }
        a[href^="http"]:after { content: " (" attr(href) ")"; font-size: 0.8em; color: #555; }
        pre, code { font-size: 10pt; }
      }
      .skip-link {
        position: absolute;
        left: -10000px;
        top: 8px;
      }
      .skip-link:focus {
        left: 8px;
        z-index: 100;
        background: var(--bg);
        color: var(--accent);
        padding: 0.4em 0.8em;
        border: 2px solid var(--accent);
        border-radius: 4px;
        font-family: var(--mono);
      }
      figure.hero-diagram {
        margin: 0 0 1.5rem;
        padding: 0;
        text-align: center;
        color: var(--fg);
      }
      figure.hero-diagram img {
        max-width: 320px;
        width: 100%;
        height: auto;
      }
      figure.diagram {
        margin: 1.5rem 0;
        text-align: center;
      }
      figure.diagram img {
        max-width: 100%;
        height: auto;
        color: var(--fg);
      }
      figure.diagram figcaption {
        font-size: 0.875rem;
        color: var(--muted);
        margin-top: 0.5rem;
      }
    </style>
  </body>
</html>
