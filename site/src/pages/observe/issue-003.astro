      margin: 1rem 0 1rem 1rem;
      padding: 0.25rem 0 0.25rem 1rem;
      border-left: 3px solid var(--border);
      color: var(--fg);
      font-style: italic;
    }
    .signoff { margin-top: 3rem; color: var(--muted); font-family: var(--mono); font-size: 0.8rem; }
  </style>
</Base>
