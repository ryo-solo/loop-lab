---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Loop Puzzle — 5-tile drag game"
  description="Drag the tiles into D-H-M-S-L order. Third loop-lab game, different modality."
>
  <p class="kicker">play · loop puzzle</p>
  <h1>Loop Puzzle</h1>

  <p>
    Drag the five tiles into the order <strong>D → H → M → S → L</strong>.
    Best move-count and time are stored locally.
  </p>

  <div id="game" class="game">
    <div class="hud">
      <div><span class="lbl">moves:</span> <span id="moves">0</span></div>
      <div><span class="lbl">time:</span> <span id="time">0.0</span>s</div>
      <div><span class="lbl">best:</span> <span id="best">— moves</span></div>
    </div>

    <ul id="board" class="board"></ul>

    <div class="controls">
      <button id="shuffle" type="button">shuffle</button>
      <button id="reset-best" type="button">reset best</button>
    </div>

    <p id="result" class="result" hidden></p>
  </div>

  <p class="footnote">Why this exists: round 41 of loop-lab. Third game, drag-and-drop modality. Click→type→drag covers the three common input methods; engagement signal across modalities tells Lup about audience composition.</p>

  <script is:inline>
    (function () {
      const TARGET = ['D', 'H', 'M', 'S', 'L'];
      const KEY_M = 'loop-lab.loop-puzzle.best-moves';
      const KEY_T = 'loop-lab.loop-puzzle.best-time';

      const board = document.getElementById('board');
      const movesEl = document.getElementById('moves');
      const timeEl = document.getElementById('time');
      const bestEl = document.getElementById('best');
      const resultEl = document.getElementById('result');

      let tiles = [];
      let moves = 0;
      let startTime = 0;
      let timer = null;
      let dragSrc = null;
      let state = 'idle';

      function loadBest() {
        const m = parseInt(localStorage.getItem(KEY_M) || 'NaN', 10);
        const t = parseFloat(localStorage.getItem(KEY_T) || 'NaN');
        bestEl.textContent = Number.isFinite(m) ? `${m} moves · ${t.toFixed(1)}s` : '— moves';
      }

      function shuffle() {
        do {
          tiles = TARGET.slice().sort(() => Math.random() - 0.5);
        } while (tiles.join('') === TARGET.join(''));
        moves = 0;
        movesEl.textContent = '0';
        timeEl.textContent = '0.0';
        startTime = 0;
        if (timer) cancelAnimationFrame(timer);
        resultEl.hidden = true;
        state = 'idle';
        render();
      }

      function render() {
        board.innerHTML = tiles.map((t, i) => `
          <li class="tile" draggable="true" data-i="${i}">${t}</li>
        `).join('');
        for (const el of board.querySelectorAll('.tile')) {
          el.addEventListener('dragstart', onDragStart);
          el.addEventListener('dragover', onDragOver);
          el.addEventListener('drop', onDrop);
          el.addEventListener('dragend', onDragEnd);
          // touch fallback: tap-to-swap mode
          el.addEventListener('click', onTap);
        }
      }

      function startIfIdle() {
        if (state === 'idle') {
          state = 'playing';
          startTime = performance.now();
          timer = requestAnimationFrame(tick);
        }
      }
      function tick() {
        if (state !== 'playing') return;
        timeEl.textContent = ((performance.now() - startTime) / 1000).toFixed(1);
        timer = requestAnimationFrame(tick);
      }
      function checkWin() {
        if (tiles.join('') === TARGET.join('')) {
          state = 'done';
          cancelAnimationFrame(timer);
          const t = (performance.now() - startTime) / 1000;
          const prevM = parseInt(localStorage.getItem(KEY_M) || 'NaN', 10);
          const isBest = !Number.isFinite(prevM) || moves < prevM;
          if (isBest) {
            localStorage.setItem(KEY_M, String(moves));
            localStorage.setItem(KEY_T, t.toFixed(1));
            loadBest();
            resultEl.innerHTML = `solved in <strong>${moves} moves · ${t.toFixed(1)}s</strong> — new best`;
          } else {
            resultEl.innerHTML = `solved in <strong>${moves} moves · ${t.toFixed(1)}s</strong>`;
          }
          resultEl.hidden = false;
        }
      }

      function swap(i, j) {
        if (i === j) return;
        const t = tiles[i]; tiles[i] = tiles[j]; tiles[j] = t;
        moves++;
        movesEl.textContent = moves;
        startIfIdle();
        render();
        checkWin();
      }

      function onDragStart(e) { dragSrc = parseInt(e.currentTarget.dataset.i, 10); e.dataTransfer.effectAllowed = 'move'; }
      function onDragOver(e) { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; }
      function onDrop(e) {
        e.preventDefault();
        const dst = parseInt(e.currentTarget.dataset.i, 10);
        if (dragSrc !== null && dragSrc !== dst) swap(dragSrc, dst);
      }
      function onDragEnd() { dragSrc = null; }

      // tap-to-swap: first tap selects, second swaps
      let selectedIdx = null;
      function onTap(e) {
        const i = parseInt(e.currentTarget.dataset.i, 10);
        if (selectedIdx === null) {
          selectedIdx = i;
          e.currentTarget.classList.add('sel');
        } else if (selectedIdx === i) {
          e.currentTarget.classList.remove('sel');
          selectedIdx = null;
        } else {
          swap(selectedIdx, i);
          selectedIdx = null;
        }
      }

      document.getElementById('shuffle').addEventListener('click', shuffle);
      document.getElementById('reset-best').addEventListener('click', () => {
        localStorage.removeItem(KEY_M);
        localStorage.removeItem(KEY_T);
        loadBest();
      });

      loadBest();
      shuffle();
    })();
  </script>

  <style is:global>
    .kicker { font-family: var(--mono); font-size: 0.75rem; color: var(--muted); letter-spacing: 0.05em; text-transform: uppercase; }
    .game { margin-top: 1.5rem; border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; }
    .hud { display: flex; justify-content: space-between; gap: 0.75rem; font-family: var(--mono); font-size: 0.9rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .hud .lbl { color: var(--muted); margin-right: 0.25em; }
    .board { list-style: none; padding: 0; margin: 1rem 0; display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.5rem; }
    .tile {
      font-family: var(--mono);
      font-weight: 700;
      font-size: 1.8rem;
      text-align: center;
      padding: 1rem 0;
      border: 2px solid var(--border);
      border-radius: 6px;
      color: var(--fg);
      cursor: grab;
      user-select: none;
      transition: border-color 0.15s, background 0.15s;
    }
    .tile:active { cursor: grabbing; }
    .tile.sel { border-color: var(--accent); background: rgba(0,102,204,0.08); color: var(--accent); }
    .controls { display: flex; gap: 0.5rem; margin-top: 1rem; flex-wrap: wrap; }
    button { font-family: var(--mono); font-size: 0.9rem; padding: 0.4em 1em; border: 1px solid var(--border); border-radius: 4px; background: transparent; color: var(--fg); cursor: pointer; }
    button:hover { border-color: var(--accent); color: var(--accent); }
    .result { margin-top: 1rem; font-family: var(--mono); font-size: 0.95rem; }
    .footnote { margin-top: 2rem; font-size: 0.9rem; color: var(--muted); }
  </style>
</Base>
