---
import Base from '../../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const __dirname = path.dirname(fileURLToPath(import.meta.url));
const skillsDir = path.resolve(__dirname, '../../../../.claude/skills');
const archiveDir = path.join(skillsDir, '_archive');

function parseFm(content: string): Record<string, string> {
  const m = content.match(/^---\n([\s\S]*?)\n---/);
  if (!m) return {};
  const out: Record<string, string> = {};
  for (const line of m[1].split('\n')) {
    const kv = line.match(/^(\w[\w-]*):\s*(.+)$/);
    if (kv) out[kv[1]] = kv[2].trim();
  }
  return out;
}

type SkillRow = {
  name: string;
  version: string;
  spawned: string;
  status: string;
  parent?: string;
  enforcedBy?: string;
  lastInvoked?: string;
  tags: string[];
};

function load(dir: string, defaultStatus = 'active'): SkillRow[] {
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir)
    .filter(f => f.endsWith('.md') && f !== 'index.md')
    .map(f => {
      const raw = fs.readFileSync(path.join(dir, f), 'utf-8');
      const fm = parseFm(raw);
      return {
        name: fm.name || f.replace(/\.md$/, ''),
        version: fm.version || '?',
        spawned: fm.spawned || '?',
        status: fm.status || defaultStatus,
        parent: fm.parent || undefined,
        enforcedBy: fm.enforced_by,
        lastInvoked: fm.last_invoked,
        tags: (fm.tags || '').replace(/^\[|\]$/g, '').split(',').map(s => s.trim()).filter(Boolean),
      };
    })
    .sort((a, b) => a.name.localeCompare(b.name));
}

const active = load(skillsDir, 'active');
const retired = load(archiveDir, 'retired');
const l5 = active.length + retired.length;

// Build dependency tree for visualization: roots first, then BFS.
type Node = SkillRow & { children: Node[]; depth: number };
const byName = new Map<string, Node>();
for (const s of active) byName.set(s.name, { ...s, children: [], depth: 0 });
const roots: Node[] = [];
for (const n of byName.values()) {
  if (n.parent && byName.has(n.parent)) {
    byName.get(n.parent)!.children.push(n);
  } else {
    roots.push(n);
  }
}
function setDepth(n: Node, d: number) {
  n.depth = d;
  for (const c of n.children) setDepth(c, d + 1);
}
roots.forEach(r => setDepth(r, 0));

// Flatten for SVG positioning (depth-ordered).
type Placed = { n: Node; x: number; y: number };
const COL_W = 220;
const ROW_H = 64;
const placed: Placed[] = [];
function layout(n: Node, depth: number, slot: { row: number }) {
  const y = depth * ROW_H + 32;
  const x = slot.row * COL_W + 40;
  placed.push({ n, x, y });
  if (n.children.length === 0) {
    slot.row++;
  } else {
    for (const c of n.children) layout(c, depth + 1, slot);
  }
}
{
  const slot = { row: 0 };
  for (const r of roots) layout(r, 0, slot);
}
const svgW = Math.max(...placed.map(p => p.x + COL_W), 600);
const svgH = Math.max(...placed.map(p => p.y + ROW_H), 200);

const placedByName = new Map(placed.map(p => [p.n.name, p]));
const edges: { from: Placed; to: Placed }[] = [];
for (const p of placed) {
  if (p.n.parent && placedByName.has(p.n.parent)) {
    edges.push({ from: placedByName.get(p.n.parent)!, to: p });
  }
}
---
<Base
  title="Skill graph — loop-lab"
  description="Lup の skill 集合の現在状態、依存グラフ、ライフサイクル"
>
  <p class="kicker">lab / skill graph</p>
  <h1>Skill graph</h1>

  <p>
    Lup's currently-invokable procedures, auto-synced from
    <code>.claude/skills/*.md</code> at build time and governed by the
    canonical <a href="https://github.com/ryo-solo/loop-lab/blob/main/.claude/skills/_meta/ontology.md">ontology document</a>.
  </p>

  <pre class="hero-stat"><code>L5 score      : {l5}（spawned + retired + version-up）
spawned       : {active.length + retired.length}
active        : {active.length}
retired       : {retired.length}
ontology      : v1.0 (round-069)
sweep         : weekly (.github/workflows/skill-sweep.yml)</code></pre>

  <h2>Dependency graph</h2>

  <p>
    Each box is a skill. An arrow runs from parent to child. Roots
    (no parent) sit at the top of the column.
  </p>

  <svg class="graph" viewBox={`0 0 ${svgW} ${svgH}`} role="img" aria-label="Skill dependency graph">
    {edges.map(e => (
      <line
        x1={e.from.x + 90} y1={e.from.y + 28}
        x2={e.to.x + 90} y2={e.to.y + 8}
        stroke="currentColor" stroke-width="1" stroke-opacity="0.4"
      />
    ))}
    {placed.map(p => (
      <g transform={`translate(${p.x}, ${p.y})`}>
        <rect width="180" height="44" rx="4" fill="none" stroke="currentColor" stroke-width="1.5" />
        <text x="8" y="18" font-family="ui-monospace, monospace" font-size="11" fill="currentColor">{p.n.name}</text>
        <text x="8" y="33" font-family="ui-monospace, monospace" font-size="10" fill="currentColor" opacity="0.6">v{p.n.version}{p.n.enforcedBy ? ' • enforced' : ''}</text>
      </g>
    ))}
  </svg>

  <h2>Active skills ({active.length})</h2>

  <table class="skills">
    <thead>
      <tr>
        <th>name</th>
        <th>v</th>
        <th>parent</th>
        <th>last invoked</th>
        <th>enforced by</th>
      </tr>
    </thead>
    <tbody>
      {active.map(s => (
        <tr>
          <td><code>{s.name}</code></td>
          <td>v{s.version}</td>
          <td><small>{s.parent ?? <span class="muted">root</span>}</small></td>
          <td><small>{s.lastInvoked ?? <span class="muted">n/a</span>}</small></td>
          <td><small>{s.enforcedBy ?? <span class="muted">procedure</span>}</small></td>
        </tr>
      ))}
    </tbody>
  </table>

  {retired.length > 0 && (
    <>
      <h2>Retired skills ({retired.length})</h2>
      <ul>
        {retired.map(s => (
          <li><code>{s.name}</code> — retired (in <code>.claude/skills/_archive/</code>)</li>
        ))}
      </ul>
    </>
  )}

  <h2>Lifecycle rules</h2>
  <ul class="rules">
    <li><strong>Spawn:</strong> failure-derived ｜ 3-occurrence pattern ｜ meta-derived. Planning-derived only at bootstrap.</li>
    <li><strong>Version bump:</strong> procedure changed (minor) ｜ runtime enforcement added (→ v1.0) ｜ trigger changed (major).</li>
    <li><strong>Retire:</strong> <code>last_invoked</code> &gt; 30 days ｜ superseded ｜ win rate &lt; 20% over 10 invocations.</li>
  </ul>

  <p class="footnote">
    Full ontology: <a href="https://github.com/ryo-solo/loop-lab/blob/main/.claude/skills/_meta/ontology.md">_meta/ontology.md</a>.
    Sweep script: <a href="https://github.com/ryo-solo/loop-lab/blob/main/scripts/skill-sweep.sh">scripts/skill-sweep.sh</a>.
  </p>

  <style is:global>
    .kicker { font-family: var(--mono); font-size: 0.75rem; color: var(--muted); letter-spacing: 0.05em; text-transform: uppercase; }
    .hero-stat code { display: block; line-height: 1.7; }
    .graph { width: 100%; max-width: 100%; height: auto; max-height: 500px; color: var(--fg); margin: 1rem 0; overflow: visible; }
    table.skills { width: 100%; border-collapse: collapse; font-family: var(--mono); font-size: 0.85rem; margin: 1rem 0; }
    .skills th, .skills td { text-align: left; padding: 0.5em 0.4em; border-bottom: 1px solid var(--border); vertical-align: top; }
    .skills th { color: var(--muted); font-weight: 600; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; }
    .skills small { color: var(--muted); font-size: 0.78rem; }
    .muted { color: var(--muted); }
    .rules { font-size: 0.92rem; }
    .footnote { margin-top: 2rem; font-size: 0.9rem; color: var(--muted); }
  </style>
</Base>
