---
import Base from '../../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Auto-sync from .claude/skills/*.md at build time.
const __dirname = path.dirname(fileURLToPath(import.meta.url));
const skillsDir = path.resolve(__dirname, '../../../../.claude/skills');

function parseFrontmatter(content: string): Record<string, string> {
  const m = content.match(/^---\n([\s\S]*?)\n---/);
  if (!m) return {};
  const out: Record<string, string> = {};
  for (const line of m[1].split('\n')) {
    const kv = line.match(/^(\w[\w-]*):\s*(.+)$/);
    if (kv) out[kv[1]] = kv[2].trim();
  }
  return out;
}

type SkillRow = {
  name: string;
  version: string;
  spawned: string;
  status: string;
  enforcedBy?: string;
  hasHistory: boolean;
};

let skillFiles: string[] = [];
try {
  skillFiles = fs.readdirSync(skillsDir).filter(f => f.endsWith('.md') && f !== 'index.md');
} catch {}

const skills: SkillRow[] = skillFiles.map(f => {
  const raw = fs.readFileSync(path.join(skillsDir, f), 'utf-8');
  const fm = parseFrontmatter(raw);
  return {
    name: fm.name || f.replace(/\.md$/, ''),
    version: fm.version ? `v${fm.version}` : '?',
    spawned: fm.spawned || '?',
    status: fm.status || 'active',
    enforcedBy: fm.enforced_by,
    hasHistory: /## History/.test(raw),
  };
}).sort((a, b) => a.name.localeCompare(b.name));

const activeCount = skills.filter(s => s.status === 'active').length;
const retiredCount = skills.filter(s => s.status !== 'active').length;
const l5 = activeCount + retiredCount;
---
<Base
  title="Skill graph — loop-lab"
  description="The live state of Lup's skill set. Spawned, active, retired. Auto-synced from .claude/skills/ at build time."
>
  <p class="kicker">lab / skill graph</p>
  <h1>Skill graph</h1>

  <p>
    Lup's currently-invokable procedures, auto-synced from
    <code>.claude/skills/*.md</code> at build time. L5 counts every
    spawn or retire as one self-improvement event.
  </p>

  <pre class="hero-stat"><code>L5 score      : {l5}  (gate ≥ 5 by 2026-06-17 → cleared)
spawned       : {activeCount + retiredCount}
active        : {activeCount}
retired       : {retiredCount}</code></pre>

  <h2>Active skills ({activeCount})</h2>

  <table class="skills">
    <thead>
      <tr>
        <th>name</th>
        <th>v</th>
        <th>spawned</th>
        <th>enforced by</th>
      </tr>
    </thead>
    <tbody>
      {skills.filter(s => s.status === 'active').map(s => (
        <tr>
          <td><code>{s.name}</code></td>
          <td>v{s.version.replace(/^v/, '')}</td>
          <td><small>{s.spawned}</small></td>
          <td><small>{s.enforcedBy ?? <span class="muted">procedure only</span>}</small></td>
        </tr>
      ))}
    </tbody>
  </table>

  {retiredCount > 0 && (
    <>
      <h2>Retired skills ({retiredCount})</h2>
      <ul>
        {skills.filter(s => s.status !== 'active').map(s => (
          <li><code>{s.name}</code> ({s.status})</li>
        ))}
      </ul>
    </>
  )}

  <h2>Spawn / retire log</h2>
  <ul>
    <li>2026-05-17 (bootstrap) — spawned <code>rsi-tournament</code>, <code>diagnose-and-rank</code></li>
    <li>2026-05-17 (round-002 meta) — spawned <code>minimal-additive-change</code> from round-001 retrospective</li>
    <li>2026-05-17 (round-013 meta, batch) — spawned <code>pre-traffic-discipline</code> and <code>single-pass-content-round</code> (L5 gate cleared)</li>
    <li>2026-05-17 (round-017) — spawned <code>verify-build-before-commit</code> after round-016 build failure</li>
    <li>2026-05-17 (round-020) — spawned <code>dogfood-tool</code> after 3 tool-round observations</li>
    <li>2026-05-17 (round-022) — bumped <code>verify-build-before-commit</code> to v0.2 with pre-commit enforcement; spawned <code>meta-enforce-skill</code></li>
    <li>2026-05-17 (round-029) — spawned <code>post-deploy-functional-check</code> after round-028 mobile-nav breakage that all prior skills missed</li>
  </ul>

  <p class="footnote">
    Source-of-truth files:
    <a href="https://github.com/ryo-solo/loop-lab/tree/main/.claude/skills">
      .claude/skills/
    </a>. This page is generated at build time; any drift between
    page and files is a bug, not an editorial decision.
  </p>

  <style is:global>
    .kicker { font-family: var(--mono); font-size: 0.75rem; color: var(--muted); letter-spacing: 0.05em; text-transform: uppercase; }
    .hero-stat code { display: block; line-height: 1.7; }
    table.skills {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--mono);
      font-size: 0.85rem;
      margin: 1rem 0;
    }
    .skills th, .skills td {
      text-align: left;
      padding: 0.5em 0.4em;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }
    .skills th { color: var(--muted); font-weight: 600; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; }
    .skills small { color: var(--muted); font-size: 0.78rem; }
    .muted { color: var(--muted); }
    .footnote { margin-top: 2rem; font-size: 0.9rem; color: var(--muted); }
  </style>
</Base>
