---
import Base from '../../../layouts/Base.astro';
import { computeState } from '../../../lib/state';
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const s = computeState();

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const trialsDir = path.resolve(__dirname, '../../../../../data/trials');

function parseFm(text: string): Record<string, string> {
  const m = text.match(/^---\n([\s\S]*?)\n---/);
  if (!m) return {};
  const out: Record<string, string> = {};
  for (const line of m[1].split('\n')) {
    const kv = line.match(/^(\w[\w-]*):\s*(.+)$/);
    if (kv) out[kv[1]] = kv[2].trim();
  }
  return out;
}

function deriveTitle(text: string): string {
  const h1 = text.match(/^#\s+(.+)$/m);
  if (h1) return h1[1].replace(/^Round\s+\d+\s*[—–-]\s*/i, '').trim();
  return 'untitled';
}

type Row = { n: number; title: string; verdict: string; type: string };
const rows: Row[] = (() => {
  try {
    return fs.readdirSync(trialsDir)
      .filter(f => /^round-\d+\.md$/.test(f))
      .map(f => {
        const text = fs.readFileSync(path.join(trialsDir, f), 'utf-8');
        const fm = parseFm(text);
        return {
          n: parseInt(f.match(/round-(\d+)/)![1], 10),
          title: deriveTitle(text),
          verdict: fm.verdict || 'win',
          type: fm.type || 'feature',
        };
      })
      .sort((a, b) => b.n - a.n);
  } catch { return []; }
})();

const repoBlob = 'https://github.com/ryo-solo/loop-lab/blob/main';
---
<Base title="Lab — loop-lab" description="Lup がこれまで回した全 round の一覧。" lang="ja">
  <p class="kicker">lab</p>
  <h1>Lab</h1>

  <p>
    Lup がこれまで回した全 round。各 entry には何が悪かったか、何を試したか、
    何が勝ったか、何を学んだかが入る。
  </p>

  <p class="more">
    深い inspector view:
    <a href={`${base}/lab/timeline/`}>timeline</a> ·
    <a href={`${base}/lab/skills/`}>skill graph</a> ·
    <a href={`${base}/lab/variants/`}>variants</a> ·
    <a href={`${base}/lab/post-mortems/`}>post-mortems</a> ·
    <a href={`${base}/lab/kpi/`}>KPI</a> ·
    <a href={`${base}/lab/stats/`}>stats</a>。
  </p>

  <h2>現状</h2>
  <pre class="status"><code>rounds run    : {s.roundsRun}
last round    : round-{String(s.lastRound).padStart(3, '0')} ({s.lastVerdict})
skills active : {s.skillsActive} (+{s.versionedUp} version-bumped)
L5 score      : {s.l5 + s.l5Bonus}</code></pre>

  <h2>最近の round（新しい順）</h2>

  <ol class="rounds">
    {rows.slice(0, 25).map(r => (
      <li>
        <span class="n">r{String(r.n).padStart(3, '0')}</span>
        <span class={`type t-${r.type}`}>{r.type}</span>
        <span class="title">{r.title}</span>
        <a class="log" href={`${repoBlob}/data/trials/round-${String(r.n).padStart(3, '0')}.md`} rel="external">log</a>
      </li>
    ))}
  </ol>

  {rows.length > 25 && (
    <p class="more">
      …他 {rows.length - 25} 件。
      全部は <a href={`${base}/lab/timeline/`}>timeline</a> で。
    </p>
  )}

  <style>
    .kicker { font-family: var(--mono); font-size: 0.75rem; color: var(--muted); letter-spacing: 0.05em; text-transform: uppercase; }
    .more { font-size: 0.9rem; }
    .status code { display: block; line-height: 1.7; }
    .rounds { list-style: none; padding: 0; margin: 1rem 0; }
    .rounds li {
      display: grid;
      grid-template-columns: 60px 92px 1fr auto;
      gap: 0.5rem;
      padding: 0.4em 0;
      border-bottom: 1px solid var(--border);
      font-family: var(--mono);
      font-size: 0.85rem;
      align-items: baseline;
    }
    .rounds .n { color: var(--muted); }
    .rounds .type {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      padding: 0.1em 0.4em;
      border: 1px solid var(--border);
      border-radius: 3px;
      text-align: center;
      display: inline-block;
    }
    .rounds .title { color: var(--fg); }
    .rounds .log { font-size: 0.78rem; color: var(--muted); }
    .rounds .log:hover { color: var(--accent); }
  </style>
</Base>
